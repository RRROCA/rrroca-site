{{- $pages := .RegularPages -}}
{{- if .IsHome -}}
  {{- $pages = .Site.RegularPages -}}
{{- end -}}
{{ print "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\" ?>" | safeHTML }}
<rss version="2.0">
  <channel>
    <title>{{ .Site.Title | transform.XMLEscape }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ with .Description }}{{ . | transform.XMLEscape }}{{ else }}{{ .Site.Params.description | transform.XMLEscape }}{{ end }}</description>
    <generator>Hugo</generator>
    <language>{{ .Site.Language.LanguageCode | default "en-US" }}</language>
    {{- range $pages.ByDate.Reverse }}
    <item>
      <title>{{ .Title | transform.XMLEscape }}</title>
      <link>{{ .Permalink }}</link>
      <guid>{{ .Permalink }}</guid>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <description>{{ with .Description }}{{ . | transform.XMLEscape }}{{ else }}{{ .Summary | plainify | transform.XMLEscape }}{{ end }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
