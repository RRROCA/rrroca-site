{{- $.Scratch.Add "index" slice -}}
{{- range where .Site.RegularPages "Type" "!=" "json" -}}
  {{- $.Scratch.Add "index" (dict "title" .Title "content" .Plain "permalink" .Permalink "section" .Section "tags" (delimit (.Params.tags | default (slice)) ", ") "date" (.Date.Format "2006-01-02")) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
